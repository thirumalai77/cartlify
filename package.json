{
  "name": "cartlify",
  "version": "0.1.2",
  "description": "Production-ready React + TypeScript e-commerce component library",
  "license": "MIT",
  "homepage": "https://github.com/thirumalai77/cartlify#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/thirumalai77/cartlify.git"
  },
  "bugs": {
    "url": "https://github.com/thirumalai77/cartlify/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles/globals.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-styles.mjs",
    "package": "npm run build && node scripts/create-package.mjs",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write src",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build && node scripts/patch-storybook-html.mjs",
    "lighthouse": "node scripts/serve-static.mjs & npx lighthouse http://localhost:6006 --output=html --output-path=./lighthouse-report.html --only-categories=performance,accessibility,best-practices,seo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "typescript": ">=4.7.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.1.0",
    "@storybook/addon-essentials": "^8.1.0",
    "@storybook/react": "^8.1.0",
    "@storybook/react-vite": "^8.1.0",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^13.3.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "storybook": "^8.1.0",
    "tailwindcss": "^3.4.4",
    "terser": "^5.48.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "5.5.4",
    "vite": "^5.3.1"
  }
}
